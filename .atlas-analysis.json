  "keyFeatures": [
    "20+ chart types including line, bar, pie, scatter, and advanced visualizations",
    "Rich interactive components with zoom, brush, tooltip, and legend",
    "Canvas and SVG rendering with high performance for large datasets",
    "Flexible data visualization with customizable themes and styling",
    "Responsive design support for mobile and desktop",
    "Server-side rendering (SSR) capability",
    "Extensive configuration through declarative options API",
    "Built-in animations and transitions"
  ],
